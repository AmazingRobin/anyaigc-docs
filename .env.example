# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI 模型(默认走 AnyAIGC 自家中转站)
DEFAULT_AI_BASE=https://your-ai-base/v1
DEFAULT_AI_KEY=sk-your-ai-key
DEFAULT_AI_MODEL=gpt-4o

# 备用免费模型(脚本 fallback)
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key

# 后台鉴权
ADMIN_PASSWORD=change-me
ADMIN_SECRET=long-random-string-for-hmac

# Cloudflare Pages 部署 Hook(任何写入后用来触发重建)
CF_DEPLOY_HOOK=https://api.cloudflare.com/client/v4/pages/webhooks/deploy_hooks/xxx

# 站点
SITE_URL=https://docs.anyaigc.com
NEXT_PUBLIC_API_BASE=
DAILY_BLOG_LIMIT=1
